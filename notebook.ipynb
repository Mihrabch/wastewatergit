"""
Wastewater-Based COVID-19 Hospitalization Forecasting Pipeline
===============================================================
Treatment plants : WWTP1, WWTP2, WWTP3, WWTP4, WWTP5, WWTP6, WWTP7
Predictive lags  : 7–21 days
Models           : Random Forest, Poisson Regression
Study region     : South Carolina, 2020–21

NOTE: This script is a pipeline demonstration sample.
      RNA spline smoothing and interpolation were performed separately in R.
"""

import re
import warnings
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import statsmodels.api as sm
from sklearn.ensemble import RandomForestRegressor
from sklearn.experimental import enable_halving_search_cv  # noqa
from sklearn.linear_model import PoissonRegressor
from sklearn.metrics import make_scorer
from sklearn.model_selection import HalvingGridSearchCV

warnings.filterwarnings("ignore")


# ── 1. Config ─────────────────────────────────────────────────────────────────

WWTP_NAMES   = ['WWTP1', 'WWTP2', 'WWTP3', 'WWTP4', 'WWTP5', 'WWTP6']
LAG_RANGE    = [7, 14, 21]
TRAIN_RATIO  = 0.9

WWTP_ZIP_MAP = {
    'WWTP1': [...],
    'WWTP2': [...],
    'WWTP3': [...],
    'WWTP4': [...],
    'WWTP5': [...],
    'WWTP6': [...],
}

MODELS = {
    'Random Forest'     : RandomForestRegressor(random_state=42),
    'Poisson Regression': PoissonRegressor(),
}


# ── 2. Load RNA (spline-smoothed outputs from R) ──────────────────────────────

def load_rna_data(paths: dict) -> pd.DataFrame:
    """
    Load per-WWTP spline-smoothed RNA Excel files and merge on Date.
    paths = {'WWTP1': 'path/to/file.xlsx', ...}
    """
    frames = []
    for wwtp, path in paths.items():
        df = pd.read_excel(path, usecols=['Date', 'Yhatu', 'Observed_RNA'])
        df.rename(columns={'Yhatu': f'{wwtp}_rna', 'Observed_RNA': f'Observed_rna_{wwtp}'}, inplace=True)
        frames.append(df)

    merged = frames[0]
    for df in frames[1:]:
        merged = merged.merge(df, on='Date', how='outer')

    merged['Date'] = pd.to_datetime(merged['Date'])
    return merged


# ── 3. Load & Process Hospitalization Data ────────────────────────────────────

def load_hospitalization_data(path: str) -> pd.DataFrame:
    df = pd.read_csv(path)
    df['Gender'] = df['SEX'].map({'M': 'M', 'F': 'F'}).fillna('U')
    return df[['ZIP', 'ADMD_new', 'Gender']]


# ── 4. Prepare WWTP RNA Windows ───────────────────────────────────────────────

def prepare_wwtp_data(merged_rna: pd.DataFrame, start_date, end_date) -> dict:
    """Filter RNA data to study window and return per-WWTP dataframes."""
    mask = (merged_rna['Date'] >= start_date) & (merged_rna['Date'] <= end_date)
    rna  = merged_rna[mask]
    return {wwtp: rna[['Date', f'{wwtp}_rna']].copy() for wwtp in WWTP_ZIP_MAP}


# ── 5. Build Daily Hospitalization Counts per WWTP ────────────────────────────

def process_hospitalization_data(hosp_data: pd.DataFrame, wwdataframe: dict,
                                  start_date, end_date) -> dict:
    """
    For each WWTP, filter hospitalizations to its ZIP codes, compute daily counts,
    fill missing dates with 0, and apply 7-day rolling smoothing.
    """
    hosp_data['ADMD_new'] = pd.to_datetime(hosp_data['ADMD_new'])
    hosp_data = hosp_data[(hosp_data['ADMD_new'] >= start_date) & (hosp_data['ADMD_new'] <= end_date)]

    hosp_dataframes = {}
    for wwtp, zip_codes in WWTP_ZIP_MAP.items():
        filtered = hosp_data[hosp_data['ZIP'].isin(zip_codes)]
        daily    = pd.crosstab(filtered['ADMD_new'], filtered['Gender']).reset_index()

        cols = [c for c in ['F', 'M', 'U'] if c in daily.columns]
        daily['Daily_ADMD']    = daily[cols].sum(axis=1)
        daily['Smoothed_ADMD'] = daily['Daily_ADMD'].rolling(7, min_periods=1).mean()

        # Fill dates present in RNA but missing in hospitalizations
        rna_dates   = wwdataframe[wwtp]['Date']
        missing     = rna_dates[~rna_dates.isin(daily['ADMD_new'])]
        missing_rows = pd.DataFrame({'ADMD_new': missing, 'Daily_ADMD': 0, 'Smoothed_ADMD': 0})
        daily        = pd.concat([daily, missing_rows]).sort_values('ADMD_new').reset_index(drop=True)

        hosp_dataframes[wwtp] = daily
    return hosp_dataframes


# ── 6. Merge RNA + Hospitalization → Combined DataFrame ──────────────────────

def build_combined_dataframe(wwdataframe: dict, hosp_dataframes: dict) -> pd.DataFrame:
    combined = pd.DataFrame()
    for wwtp in WWTP_ZIP_MAP:
        merged = pd.merge(
            wwdataframe[wwtp],
            hosp_dataframes[wwtp][['ADMD_new', 'Smoothed_ADMD']],
            left_on='Date', right_on='ADMD_new', how='outer'
        ).rename(columns={f'{wwtp}_rna': f'SARS_CoV2_{wwtp}', 'Smoothed_ADMD': f'Smoothed_ADMD_{wwtp}'})

        combined = merged if combined.empty else pd.merge(
            combined, merged[['Date', f'SARS_CoV2_{wwtp}', f'Smoothed_ADMD_{wwtp}']],
            on='Date', how='outer'
        )

    # Log-transform RNA columns
    rna_cols = [c for c in combined.columns if re.search(r'SARS_CoV2_WWTP\d+', c)]
    combined[rna_cols] = np.log1p(combined[rna_cols].to_numpy())
    return combined


# ── 7. Train / Test Split ─────────────────────────────────────────────────────

def split_data(combined_df: pd.DataFrame):
    combined_df['Date'] = pd.to_datetime(combined_df['Date'])
    idx        = int(len(combined_df) * TRAIN_RATIO)
    split_date = combined_df.loc[idx, 'Date']
    train      = combined_df[combined_df['Date'] <= split_date].copy()
    test       = combined_df[combined_df['Date'] >  split_date].copy()
    print(f"Split: {split_date.date()} | Train {train.shape} | Test {test.shape}")
    return train, test, split_date


# ── 8. Generate Lagged Features ───────────────────────────────────────────────

def generate_lagged_data(train: pd.DataFrame, test: pd.DataFrame):
    """
    Shift hospitalization forward by `lag` days to align with RNA signal.
    Preserves the last `lag` RNA observations from train for test continuity.
    """
    train_lag, test_lag = {}, {}
    last_rna, last_days = {}, {}

    for lag in LAG_RANGE:
        t_hosp, t_sars = pd.DataFrame(), pd.DataFrame()
        e_hosp, e_sars = pd.DataFrame(), pd.DataFrame()

        for wwtp in WWTP_ZIP_MAP:
            t_hosp[f'Lagged_ADMD_{wwtp}_{lag}'] = train[f'Smoothed_ADMD_{wwtp}'].iloc[lag:].reset_index(drop=True)
            t_hosp['Date_Hosp']                  = train['Date'].iloc[lag:].reset_index(drop=True)
            t_sars[f'SARS_CoV2_{wwtp}']          = train[f'SARS_CoV2_{wwtp}'].iloc[:-lag].reset_index(drop=True)
            t_sars['Date']                        = train['Date'].iloc[:-lag].reset_index(drop=True)

            last_rna[(wwtp, lag)]  = train[f'SARS_CoV2_{wwtp}'].iloc[-lag:].reset_index(drop=True)
            last_days[(wwtp, lag)] = train['Date'].iloc[-lag:].reset_index(drop=True)

            e_hosp[f'Lagged_ADMD_{wwtp}_{lag}'] = test[f'Smoothed_ADMD_{wwtp}'].reset_index(drop=True)
            e_hosp['Date_Hosp']                  = test['Date'].reset_index(drop=True)
            e_sars[f'SARS_CoV2_{wwtp}']          = pd.concat([last_rna[(wwtp, lag)],
                                                               test[f'SARS_CoV2_{wwtp}'].iloc[:-lag].reset_index(drop=True)
                                                               ]).reset_index(drop=True)
            e_sars['Date'] = pd.concat([last_days[(wwtp, lag)],
                                        test['Date'].iloc[:-lag].reset_index(drop=True)
                                        ]).reset_index(drop=True)

        train_lag[lag] = pd.concat([t_hosp, t_sars], axis=1).dropna().reset_index(drop=True)
        test_lag[lag]  = pd.concat([e_hosp, e_sars], axis=1).dropna().reset_index(drop=True)

    return train_lag, test_lag


# ── 9. Train & Evaluate Models ────────────────────────────────────────────────

def percentage_agreement(y_true, y_pred):
    y_true, y_pred = np.array(y_true), np.array(y_pred)
    return np.mean(np.minimum(y_true, y_pred) / np.maximum(y_true, np.maximum(y_pred, 1e-9))) * 100


def run_models(train_lag: dict, test_lag: dict) -> tuple:
    """Train Random Forest and Poisson Regression for each WWTP × lag combination."""
    results, y_preds, y_tests = [], {}, {}

    drop_cols = lambda lag: ['Date', 'Date_Hosp'] + [f'Lagged_ADMD_{w}_{lag}' for w in WWTP_ZIP_MAP]

    for lag in LAG_RANGE:
        for wwtp in WWTP_ZIP_MAP:
            X_train = train_lag[lag].drop(columns=drop_cols(lag))
            y_train = train_lag[lag][f'Lagged_ADMD_{wwtp}_{lag}'].round().astype(int)
            X_test  = test_lag[lag].drop(columns=drop_cols(lag))
            y_test  = test_lag[lag][f'Lagged_ADMD_{wwtp}_{lag}'].round().astype(int)

            y_tests.setdefault(wwtp, {})[lag] = y_test

            for name, model in MODELS.items():
                model.fit(X_train, y_train)
                y_pred = model.predict(X_test)
                y_preds.setdefault(wwtp, {}).setdefault(lag, {})[name] = y_pred
                results.append({'WWTP': wwtp, 'Model': name, 'Lag': lag,
                                 'PA': percentage_agreement(y_test, y_pred)})

    return pd.DataFrame(results), y_preds, y_tests


# ── 10. Statsmodels Poisson (with significance filtering) ────────────────────

def run_statsmodels_poisson(train_lag: dict, test_lag: dict) -> tuple:
    y_preds, y_tests, params = {}, {}, []
    drop_cols = lambda lag: ['Date', 'Date_Hosp'] + [f'Lagged_ADMD_{w}_{lag}' for w in WWTP_ZIP_MAP]

    for lag in LAG_RANGE:
        for wwtp in WWTP_ZIP_MAP:
            X_tr = sm.add_constant(train_lag[lag].drop(columns=drop_cols(lag)))
            X_te = sm.add_constant(test_lag[lag].drop(columns=drop_cols(lag)))
            y_tr = train_lag[lag][f'Lagged_ADMD_{wwtp}_{lag}'].round().astype(int)
            y_te = test_lag[lag][f'Lagged_ADMD_{wwtp}_{lag}'].round().astype(int)

            fit    = sm.GLM(y_tr, X_tr, family=sm.families.Poisson()).fit()
            y_pred = fit.predict(X_te)

            y_preds.setdefault(wwtp, {})[lag] = {'Poisson Regression': y_pred}
            y_tests.setdefault(wwtp, {})[lag] = y_te

            for feat, coef, pval in zip(X_tr.columns, fit.params, fit.pvalues):
                if feat != 'const' and pval < 0.05:
                    params.append({'WWTP': wwtp, 'Lag': lag, 'Feature': feat,
                                   'Coefficient': coef, 'P-value': pval})
    return y_preds, y_tests, pd.DataFrame(params)


# ── 11. Weekly Percentage Agreement ──────────────────────────────────────────

def evaluate_weekly_pa(y_preds: dict, y_tests: dict) -> pd.DataFrame:
    records = []
    for wwtp in WWTP_ZIP_MAP:
        for lag in LAG_RANGE:
            for model_name, y_pred in y_preds[wwtp][lag].items():
                pred_s  = pd.Series(np.ravel(y_pred))
                test_s  = pd.Series(np.ravel(y_tests[wwtp][lag]))
                pred_wk = pred_s.groupby(pred_s.index // 7).sum()
                test_wk = test_s.groupby(test_s.index // 7).sum()
                for wk in range(len(test_wk)):
                    records.append({'WWTP': wwtp, 'Model': model_name, 'Lag': lag,
                                    'Week': wk + 1,
                                    'PA': percentage_agreement(test_wk.iloc[wk], pred_wk.iloc[wk])})
    return pd.DataFrame(records)


# ── 12. Summarize Performance ─────────────────────────────────────────────────

def summarize_performance(weekly_df: pd.DataFrame) -> pd.DataFrame:
    avg = weekly_df.groupby(['WWTP', 'Model', 'Lag'])['PA'].mean().reset_index()
    summary = avg.groupby(['Model', 'Lag'])['PA'].agg(
        Min='min', Q1=lambda x: x.quantile(0.25), Mean='mean',
        Median='median', Q3=lambda x: x.quantile(0.75), Max='max'
    ).reset_index()
    summary['IQR'] = summary['Q3'] - summary['Q1']
    return summary.round(2)


# ── 13. Hyperparameter Tuning (Random Forest) ─────────────────────────────────

def tune_random_forest(train_lag: dict) -> dict:
    pa_scorer  = make_scorer(percentage_agreement, greater_is_better=True)
    param_grid = {'n_estimators': [1500, 2000, 3000, 5000], 'max_depth': [10, None]}
    best_params = {}
    drop_cols   = lambda lag: ['Date', 'Date_Hosp'] + [f'Lagged_ADMD_{w}_{lag}' for w in WWTP_ZIP_MAP]

    for lag in LAG_RANGE:
        for wwtp in WWTP_ZIP_MAP:
            X_tr = train_lag[lag].drop(columns=drop_cols(lag))
            y_tr = train_lag[lag][f'Lagged_ADMD_{wwtp}_{lag}'].round().astype(int)
            search = HalvingGridSearchCV(RandomForestRegressor(random_state=42),
                                         param_grid, scoring=pa_scorer, cv=5, factor=2, n_jobs=-1)
            search.fit(X_tr, y_tr)
            best_params[(wwtp, lag)] = search.best_params_
            print(f"{wwtp} | lag {lag} | best: {search.best_params_}")
    return best_params


# ── Main ──────────────────────────────────────────────────────────────────────

if __name__ == '__main__':

 

    # Paths — fill in before running
    RNA_PATHS  = {wwtp: f'data/rna_{wwtp.lower()}.xlsx' for wwtp in WWTP_NAMES}
    HOSP_PATH  = 'data/hospitalization.csv'

    # Pipeline
    merged_rna        = load_rna_data(RNA_PATHS)
    hosp_raw          = load_hospitalization_data(HOSP_PATH)
    wwdataframe       = prepare_wwtp_data(merged_rna, START_DATE, END_DATE)
    hosp_dataframes   = process_hospitalization_data(hosp_raw, wwdataframe, START_DATE, END_DATE)
    combined_df       = build_combined_dataframe(wwdataframe, hosp_dataframes)
    train, test, _    = split_data(combined_df)
    train_lag, test_lag = generate_lagged_data(train, test)

    results_df, y_preds, y_tests = run_models(train_lag, test_lag)
    weekly_df                    = evaluate_weekly_pa(y_preds, y_tests)
    summary                      = summarize_performance(weekly_df)

    print(summary)
